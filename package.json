{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "An Electron application with Solid and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.3.9",
    "solid-devtools": "^0.34.3",
    "vite": "^7.1.4",
    "@kobalte/core": "^0.13.11",
    "@neodrag/solid": "3.0.0-next.8",
    "@tabler/icons-solidjs": "^3.35.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/solid-table": "^8.21.3",
    "@thednp/solid-color-picker": "^0.0.14",
    "@thisbeyond/solid-dnd": "^0.7.5",
    "@tiptap/core": "^3.7.0",
    "@tiptap/extension-blockquote": "^3.7.0",
    "@tiptap/extension-heading": "^3.7.0",
    "@tiptap/extension-highlight": "^3.7.0",
    "@tiptap/extension-list": "^3.7.0",
    "@tiptap/extension-paragraph": "^3.7.0",
    "@tiptap/extension-strike": "^3.7.0",
    "@tiptap/extension-text": "^3.7.0",
    "@tiptap/extension-text-align": "^3.7.0",
    "@tiptap/extension-text-style": "^3.7.0",
    "@tiptap/extension-typography": "^3.7.0",
    "@tiptap/extension-underline": "^3.7.0",
    "@tiptap/pm": "^3.7.0",
    "@tiptap/starter-kit": "^3.7.0",
    "arrows-svg": "^1.8.1",
    "cal-heatmap": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "solid-color": "^0.0.6",
    "solid-colorful": "^0.0.2",
    "solid-js": "^1.9.9",
    "solid-tiptap": "^0.8.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tinymce-solid": "^0.0.10"
  
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.7.4",
    "solid-js": "^1.9.10",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-solid": "^2.11.10",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "router": "^2.2.0",
    "tailwindcss": "^4.1.14"
  
  }
}
